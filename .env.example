# Public site URL (canonical, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://fmemari.com

# ─── Vercel AI Gateway (chatbot + contact-form classifier) ───
# Auth is automatic on Vercel deployments via OIDC.
# Local dev: `vercel link` then `vercel env pull .env.local` provisions VERCEL_OIDC_TOKEN (~24h).
# Optional CI fallback (non-Vercel envs):
# AI_GATEWAY_API_KEY=

# Optional model overrides — must use `provider/model` slug routed via AI Gateway.
# Defaults: openai/gpt-oss-20b for both. See https://vercel.com/docs/ai-gateway for the model list.
AI_CHAT_MODEL=openai/gpt-oss-20b
CONTACT_CLASSIFY_MODEL=openai/gpt-oss-20b

# Email — optional; without RESEND_API_KEY, contact form logs server-side only
RESEND_API_KEY=
# Must be a verified sender in Resend, e.g. Dr. Fereidoon Memari <hello@fmemari.com>
RESEND_FROM_EMAIL=
CONTACT_TO_EMAIL=memarife@tums.ac.ir
