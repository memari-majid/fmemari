# Public site URL (canonical, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://fmemari.com

# OpenAI — optional. Used by /api/contact for academic-inquiry classification + auto-reply.
# Without OPENAI_API_KEY, the contact form still works and falls back to a generic acknowledgment.
OPENAI_API_KEY=
# Optional model for inquiry classification (default: gpt-4o-mini)
CONTACT_CLASSIFY_MODEL=gpt-4o-mini

# Email — optional; without RESEND_API_KEY, contact form logs server-side only
RESEND_API_KEY=
# Must be a verified sender in Resend, e.g. Dr. Fereidoon Memari <hello@fmemari.com>
RESEND_FROM_EMAIL=
CONTACT_TO_EMAIL=memarife@tums.ac.ir
